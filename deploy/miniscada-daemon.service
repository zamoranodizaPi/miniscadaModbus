[Unit]
Description=Mini SCADA Modbus Poller
After=network-online.target miniscada-simulator.service
Wants=network-online.target

[Service]
Type=simple
User=__APP_USER__
WorkingDirectory=__APP_DIR__
EnvironmentFile=/etc/default/miniscada
ExecStart=__APP_DIR__/.venv/bin/python -m daemon.service
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
